{
  "name": "@manju/asset-service",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run test/integration",
    "typecheck": "tsc --noEmit",
    "migrate": "atlas migrate apply --env local"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "pino-pretty": "^11.3.0",
    "uuid": "^11.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["cpu-features", "esbuild", "protobufjs", "ssh2"]
  }
