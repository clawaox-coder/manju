# copy to .env.local, 本地随便填. 生产值走 KMS / vault.

# postgres
POSTGRES_DB=manju
POSTGRES_USER=manju
POSTGRES_PASSWORD=manju

# minio (s3-compatible)
MINIO_ROOT_USER=manjuadmin
MINIO_ROOT_PASSWORD=manjuadmin

# openai-compatible 图像生成 (ai-gateway). 留空则图像生成不可用(503)。
# 可指向中转网关: OPENAI_IMAGE_BASE_URL=https://<gateway>/v1/images, OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1/images
OPENAI_IMAGE_MODEL=gpt-image-1
